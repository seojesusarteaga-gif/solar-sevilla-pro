---
import Layout from "../layouts/Layout.astro";
import { services } from "../data/services";
---

<Layout
  title="Servicios de Placas Solares en Sevilla | Solar Sevilla Pro"
  description="Instalación residencial, comercial e industrial de placas solares en Sevilla, además de mantenimiento y revisión de instalaciones existentes. Presupuesto gratuito."
>
  <section class="section intro">
    <div class="container">
      <span class="eyebrow">Servicios</span>
      <h1>Servicios de instalación de placas solares en Sevilla</h1>
      <p>
        Trabajamos tres líneas de servicio: instalación residencial, instalación
        comercial e industrial, y mantenimiento de instalaciones ya existentes. Cada
        proyecto empieza con un estudio de tu consumo real antes de proponerte nada.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container grid">
      {
        services.map((service) => (
          <a class="card" href={`/servicios/${service.slug}`}>
            <h2>{service.title}</h2>
            <p>{service.summary}</p>
            <span class="link">Ver detalles, proceso y precios →</span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .intro p {
    max-width: 60ch;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    display: block;
    background: var(--color-white);
    border: 1px solid #e6e9f0;
    border-radius: 12px;
    padding: 1.75rem;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .card:hover {
    border-color: var(--color-solar-yellow);
    transform: translateY(-2px);
  }

  .card h2 {
    color: var(--color-navy);
    font-size: 1.3rem;
  }

  .card p {
    margin: 0 0 1rem;
  }

  .card .link {
    color: var(--color-navy);
    font-weight: 700;
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
