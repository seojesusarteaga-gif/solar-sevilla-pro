---
import Layout from "../layouts/Layout.astro";
import { services } from "../data/services";
import { site } from "../data/site";
---

<Layout
  title={`Servicios de Placas Solares en Sevilla | ${site.name}`}
  description="Instalación residencial, comercial e industrial de placas solares en Sevilla. Mantenimiento de instalaciones existentes. Presupuesto gratuito en 24h."
>
  <section class="section intro">
    <div class="container intro-grid">
      <div>
        <span class="eyebrow">Servicios</span>
        <h1>Servicios de instalación de placas solares en Sevilla</h1>
        <p>
          Trabajamos tres líneas de servicio: instalación residencial, instalación
          comercial e industrial, y mantenimiento de instalaciones ya existentes. Cada
          proyecto empieza con un estudio de tu consumo real antes de proponerte nada.
        </p>
      </div>
      <img
        class="intro-image"
        src="https://images.unsplash.com/photo-1660330589243-4c640d878052?w=800&q=75&fm=webp&fit=crop"
        alt="Equipo técnico instalando placas solares en un tejado"
        width="900"
        height="600"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section section-alt">
    <div class="container grid">
      {
        services.map((service) => (
          <a class="card" href={`/servicios/${service.slug}`}>
            <h2>{service.title}</h2>
            <p>{service.summary}</p>
            <span class="link">Ver detalles, proceso y precios →</span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: center;
  }

  .intro p {
    max-width: 60ch;
  }

  .intro-image {
    width: 100%;
    height: auto;
    border-radius: 16px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    display: block;
    background: var(--color-white);
    border: 1px solid #e6e9f0;
    border-radius: 12px;
    padding: 1.75rem;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .card:hover {
    border-color: var(--color-solar-yellow);
    transform: translateY(-2px);
  }

  .card h2 {
    color: var(--color-navy);
    font-size: 1.3rem;
  }

  .card p {
    margin: 0 0 1rem;
  }

  .card .link {
    color: var(--color-navy);
    font-weight: 700;
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .intro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
