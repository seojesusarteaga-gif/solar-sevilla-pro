---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/Icon.astro";
import Faq from "../../components/Faq.astro";
import { site } from "../../data/site";
import { provinceMunicipalities } from "../../data/coverage";

export function getStaticPaths() {
  return provinceMunicipalities.map((town) => ({
    params: { slug: town.slug },
    props: { town },
  }));
}

const { town } = Astro.props;

const localBusinessSchema = {
  "@type": "LocalBusiness",
  name: site.name,
  telephone: site.phoneHref.replace("tel:", ""),
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address.street,
    postalCode: site.address.postalCode,
    addressLocality: site.address.city,
    addressCountry: "ES",
  },
  areaServed: {
    "@type": "City",
    name: town.name,
  },
};

const faqSchema = {
  "@type": "FAQPage",
  mainEntity: town.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<Layout
  title={`Placas Solares en ${town.name} | ${site.name}`}
  description={`Instalación de placas solares en ${town.name}. Presupuesto gratuito en 24h, instaladores certificados y financiación disponible. Llama al 954 123 456.`}
  extraSchema={[localBusinessSchema, faqSchema]}
>
  <section class="section intro">
    <div class="container intro-grid">
      <div>
        <a class="back-link" href="/zona-cobertura">← Volver a zona de cobertura</a>
        <span class="eyebrow">Zona de cobertura</span>
        <h1>Placas solares en {town.name}</h1>
        <p>{town.intro}</p>
        <a class="btn btn-primary" href="/contacto">Solicitar presupuesto en {town.name}</a>
      </div>
      <img
        class="intro-image"
        src={town.image.src}
        alt={town.image.alt}
        width="900"
        height="600"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>Datos de {town.name}</h2>
      <div class="data-grid">
        <div class="data-card">
          <span class="data-label">Población</span>
          <p>{town.population}</p>
        </div>
        <div class="data-card">
          <span class="data-label">Vivienda predominante</span>
          <p>{town.housingType}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Por qué instalar placas solares en {town.name}</h2>
      <ul class="highlights">
        {
          town.highlights.map((highlight) => (
            <li>
              <Icon name="check" class="check" />
              <span>{highlight}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container solar-fit-card">
      <span class="eyebrow">¿Tiene sentido instalar aquí?</span>
      <h2>Por qué compensa en {town.name}</h2>
      <p>{town.solarFit}</p>
    </div>
  </section>

  <section class="section">
    <div class="container context-grid">
      <div class="context-card">
        <h2>Clima y producción solar en {town.name}</h2>
        <p>{town.energyContext}</p>
      </div>
      <div class="context-card">
        <h2>Ayudas y bonificaciones locales</h2>
        <p>{town.subsidyNote}</p>
      </div>
    </div>
  </section>

  <Faq items={town.faq} title={`Preguntas frecuentes sobre placas solares en ${town.name}`} />

  <section class="section cta-section">
    <div class="container cta-inner">
      <div>
        <h2>¿Instalamos placas solares en tu vivienda o negocio en {town.name}?</h2>
        <p>Pide tu presupuesto gratuito y sin compromiso hoy mismo.</p>
      </div>
      <div class="actions">
        <a class="btn btn-primary" href="/contacto">Pide tu presupuesto gratuito</a>
        <a class="btn btn-secondary" href={site.whatsappHref} target="_blank" rel="noopener noreferrer">
          <Icon name="chat" />
          <span>WhatsApp: {site.phone}</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section back-section">
    <div class="container">
      <a class="back-link" href="/zona-cobertura">← Ver todos los municipios de la zona de cobertura</a>
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: block;
    margin-bottom: 1.5rem;
    color: var(--color-navy);
    font-weight: 600;
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: center;
  }

  .intro p {
    max-width: 65ch;
  }

  .intro-image {
    width: 100%;
    height: auto;
    border-radius: 16px;
  }

  .data-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .data-card {
    background: var(--color-white);
    border: 1px solid #e6e9f0;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .data-label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 700;
    color: var(--color-solar-yellow);
    background: var(--color-navy);
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }

  .data-card p {
    margin: 0;
    color: var(--color-navy);
    font-weight: 600;
  }

  .solar-fit-card {
    max-width: 760px;
  }

  .solar-fit-card p {
    max-width: 70ch;
  }

  .context-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .context-card {
    background: var(--color-offwhite);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .context-card h2 {
    color: var(--color-navy);
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
  }

  .context-card p {
    margin: 0;
  }

  .highlights {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
  }

  .highlights li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .highlights :global(.check) {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--color-navy);
    background: var(--color-solar-yellow);
    border-radius: 50%;
    padding: 5px;
    margin-top: 0.1rem;
  }

  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    background: var(--color-navy);
    color: var(--color-white);
    border-radius: 16px;
    padding: 2.5rem;
  }

  .cta-inner h2 {
    color: var(--color-white);
    margin-bottom: 0.3rem;
    max-width: 40ch;
  }

  .cta-inner p {
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .back-section {
    padding-top: 0;
  }

  @media (max-width: 760px) {
    .intro-grid,
    .context-grid,
    .data-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
