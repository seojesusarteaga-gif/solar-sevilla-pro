---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ServicesTeaser from "../components/ServicesTeaser.astro";
import WhyUsTeaser from "../components/WhyUsTeaser.astro";
import CoverageTeaser from "../components/CoverageTeaser.astro";
import QuoteSection from "../components/QuoteSection.astro";
import Faq from "../components/Faq.astro";
import BatteryBackup from "../components/BatteryBackup.astro";
import BusinessSummary from "../components/BusinessSummary.astro";
import SocialProof from "../components/SocialProof.astro";
import SavingsPAS from "../components/SavingsPAS.astro";
import { faq } from "../data/faq";
import { site } from "../data/site";
---

<Layout
  title={`Instalación de Placas Solares en Sevilla | ${site.name}`}
  description="Instalación de placas solares en Sevilla capital y provincia. Presupuesto gratuito en 24h, instaladores certificados y financiación disponible. Llama al 954 123 456."
  faq={faq}
>
  <Hero />
  <SocialProof />
  <SavingsPAS />
  <WhyUsTeaser />
  <ServicesTeaser />
  <BatteryBackup />
  <CoverageTeaser />
  <Faq items={faq} />
  <BusinessSummary />
  <QuoteSection />
</Layout>
