---
import { services } from "../data/services";
---

<section class="section">
  <div class="container">
    <span class="eyebrow">Servicios</span>
    <h2>Soluciones fotovoltaicas para cada necesidad</h2>
    <div class="grid">
      {
        services.map((service) => (
          <a class="card" href={`/servicios/${service.slug}`}>
            <img
              class="card-image"
              src={`${service.image.src}?w=600&q=75&auto=format&fit=crop`}
              alt={service.image.alt}
              loading="lazy"
              width="600"
              height="360"
            />
            <div class="card-body">
              <h3>{service.title}</h3>
              <p class="tagline">{service.tagline}</p>
              <p>{service.summary}</p>
            </div>
          </a>
        ))
      }
    </div>
    <a class="btn btn-primary" href="/servicios">Ver todos los servicios</a>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin: 2rem 0 2.5rem;
  }

  .card {
    display: block;
    background: var(--color-white);
    border: 1px solid #e6e9f0;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .card:hover {
    border-color: var(--color-solar-yellow);
    transform: translateY(-2px);
  }

  .card-image {
    width: 100%;
    height: 160px;
    object-fit: cover;
  }

  .card-body {
    padding: 1.75rem;
  }

  .card h3 {
    color: var(--color-navy);
    margin-bottom: 0.2rem;
  }

  .tagline {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-solar-yellow) !important;
    background: var(--color-navy);
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 0.75rem !important;
  }

  .card p {
    margin: 0;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
