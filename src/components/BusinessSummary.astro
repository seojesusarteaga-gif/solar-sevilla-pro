---
import { site } from "../data/site";
import { services } from "../data/services";
import { capital, provinceMunicipalities } from "../data/coverage";

const zones = [capital.name, ...provinceMunicipalities.map((t) => t.name)].join(", ");
---

<section class="section summary">
  <div class="container">
    <span class="eyebrow">Resumen</span>
    <h2>{site.name}, en una página</h2>
    <p>
      {site.name} es una empresa de instalación y mantenimiento de placas
      solares (autoconsumo fotovoltaico) que opera en Sevilla capital y en la
      provincia de Sevilla, España. Teléfono y WhatsApp: {site.phone}. Email:{" "}
      {site.email}. Dirección: {site.address.street}, {site.address.postalCode}{" "}
      {site.address.city}.
    </p>

    <h3>Servicios y precios orientativos</h3>
    <ul class="summary-list">
      {
        services.map((service) => (
          <li>
            <strong>{service.title}:</strong> {service.summary} {service.priceRange}
          </li>
        ))
      }
    </ul>

    <h3>Zona de cobertura</h3>
    <p>Instalamos en: {zones}.</p>

    <h3>Tiempos y confianza</h3>
    <p>
      Presupuesto gratuito en menos de 24 horas. Instaladores certificados en
      Sevilla. Financiación disponible. Más de 10 años de experiencia y más de
      350 instalaciones realizadas en Sevilla y su provincia. Garantía de
      producto de 25 años en los paneles solares.
    </p>
  </div>
</section>

<style>
  .summary h3 {
    color: var(--color-navy);
    font-size: 1.1rem;
    margin-top: 1.75rem;
  }

  .summary p {
    max-width: 75ch;
  }

  .summary-list {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 75ch;
  }

  .summary-list strong {
    color: var(--color-navy);
  }
</style>
