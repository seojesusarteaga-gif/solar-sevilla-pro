---
import Icon from "./Icon.astro";
import { navLinks } from "../data/nav";
import { site } from "../data/site";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="bar">
    <a href="/" class="logo">
      <Icon name="sun" class="logo-icon" />
      <span>{site.name}</span>
    </a>

    <nav class="nav" id="site-nav">
      <ul>
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={currentPath === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      class="whatsapp"
      href={site.whatsappHref}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Escríbenos por WhatsApp"
    >
      <Icon name="chat" class="whatsapp-icon" />
    </a>

    <a class="phone" href={site.phoneHref}>
      <Icon name="phone" class="phone-icon" />
      <span>{site.phone}</span>
    </a>

    <button
      class="menu-toggle"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Abrir menú"
    >
      <Icon name="menu" class="icon-open" />
      <Icon name="close" class="icon-close" />
    </button>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const nav = document.getElementById("site-nav");

  toggle?.addEventListener("click", () => {
    const isOpen = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
    toggle.classList.toggle("open", Boolean(isOpen));
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-navy);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .bar {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-white);
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .logo :global(.logo-icon) {
    width: 26px;
    height: 26px;
    color: var(--color-solar-yellow);
  }

  .nav {
    flex: 1;
  }

  .nav ul {
    list-style: none;
    display: flex;
    gap: 1.75rem;
    margin: 0;
    padding: 0;
  }

  .nav a {
    color: var(--color-white);
    text-decoration: none;
    font-size: 0.95rem;
    opacity: 0.85;
  }

  .nav a:hover,
  .nav a[aria-current="page"] {
    opacity: 1;
    color: var(--color-solar-yellow);
  }

  .whatsapp {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    color: var(--color-white);
  }

  .whatsapp:hover {
    border-color: var(--color-solar-yellow);
    color: var(--color-solar-yellow);
  }

  .whatsapp :global(.whatsapp-icon) {
    width: 19px;
    height: 19px;
  }

  .phone {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-navy);
    background: var(--color-solar-yellow);
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .phone :global(.phone-icon) {
    width: 16px;
    height: 16px;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--color-white);
    cursor: pointer;
    padding: 0.25rem;
  }

  .menu-toggle :global(svg) {
    width: 26px;
    height: 26px;
  }

  .menu-toggle :global(.icon-close) {
    display: none;
  }

  .menu-toggle.open :global(.icon-open) {
    display: none;
  }

  .menu-toggle.open :global(.icon-close) {
    display: block;
  }

  @media (max-width: 860px) {
    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-navy);
      display: none;
      padding: 1rem 1.25rem 1.5rem;
    }

    .nav.open {
      display: block;
    }

    .nav ul {
      flex-direction: column;
      gap: 1rem;
    }

    .menu-toggle {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .bar {
      gap: 0.4rem;
      padding: 0.6rem 0.75rem;
    }

    .logo {
      gap: 0.3rem;
    }

    .logo span {
      font-size: 0.85rem;
    }

    .phone {
      padding: 0.35rem 0.5rem;
      font-size: 0.8rem;
    }

    .phone :global(.phone-icon) {
      width: 13px;
      height: 13px;
    }

    .whatsapp {
      width: 30px;
      height: 30px;
    }

    .whatsapp :global(.whatsapp-icon) {
      width: 15px;
      height: 15px;
    }
  }
</style>
