---
import Icon from "./Icon.astro";
---

<div id="chatbot">
  <button class="chat-fab" id="chat-fab" aria-label="Abrir chat">
    <Icon name="chat" class="fab-icon" />
  </button>

  <div class="chat-window" id="chat-window" hidden>
    <div class="chat-header">
      <div class="chat-header-info">
        <Icon name="sun" class="chat-logo" />
        <div>
          <span class="chat-brand">Hispalense Solar</span>
          <span class="chat-status">En línea</span>
        </div>
      </div>
      <button class="chat-close" id="chat-close" aria-label="Cerrar chat">
        <Icon name="close" class="close-icon" />
      </button>
    </div>
    <div class="chat-messages" id="chat-messages"></div>
    <div class="chat-options" id="chat-options" hidden></div>
    <form class="chat-input-form" id="chat-form">
      <input
        type="text"
        class="chat-input"
        id="chat-input"
        placeholder="Escribe tu mensaje..."
        autocomplete="off"
      />
      <button type="submit" class="chat-send" aria-label="Enviar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
  const STEPS = [
    {
      key: "greeting",
      bot: "Hola, soy el asistente de Hispalense Solar. ¿Estás pensando en instalar placas solares? Te ayudo y te paso presupuesto sin compromiso.",
      options: ["Sí, quiero información", "Solo estoy mirando"],
      next: (answer: string) => "name",
    },
    {
      key: "name",
      bot: "Perfecto. ¿Cómo te llamas?",
      field: "name",
      next: () => "type",
    },
    {
      key: "type",
      bot: (data: Record<string, string>) => `Encantado, ${data.name}. ¿La instalación sería para una vivienda o para un negocio/nave?`,
      options: ["Residencial (vivienda)", "Comercial (negocio/nave)"],
      field: "installation_type",
      transform: (v: string) => v.startsWith("Residencial") ? "Residencial" : "Comercial",
      next: () => "municipality",
    },
    {
      key: "municipality",
      bot: "¿En qué municipio de Sevilla se encuentra?",
      options: ["Sevilla capital", "Dos Hermanas", "Alcalá de Guadaíra", "Otro municipio"],
      field: "municipality",
      next: () => "roof",
    },
    {
      key: "roof",
      bot: "¿Tienes tejado o cubierta propia donde instalar los paneles?",
      options: ["Sí, tengo tejado propio", "No, es comunitario", "No estoy seguro"],
      field: "own_roof",
      next: () => "phone",
    },
    {
      key: "phone",
      bot: "Último paso. ¿En qué teléfono te contactamos para darte el presupuesto?",
      field: "phone",
      validate: (v: string) => /\d{9}/.test(v.replace(/\s/g, "")) ? null : "Por favor, introduce un teléfono válido de 9 dígitos.",
      next: () => "confirm",
    },
    {
      key: "confirm",
      bot: (data: Record<string, string>) =>
        `Perfecto, confirmo tus datos:\n• Nombre: ${data.name}\n• Tipo: ${data.installation_type}\n• Municipio: ${data.municipality}\n• Tejado: ${data.own_roof}\n• Teléfono: ${data.phone}\n\n¿Todo correcto?`,
      options: ["Sí, enviar", "No, corregir"],
      next: (answer: string) => answer.startsWith("Sí") ? "send" : "name",
    },
  ];

  const fab = document.getElementById("chat-fab")!;
  const win = document.getElementById("chat-window")!;
  const closeBtn = document.getElementById("chat-close")!;
  const messagesEl = document.getElementById("chat-messages")!;
  const optionsEl = document.getElementById("chat-options")!;
  const form = document.getElementById("chat-form") as HTMLFormElement;
  const input = document.getElementById("chat-input") as HTMLInputElement;

  const data: Record<string, string> = {};
  let currentStep = 0;
  let done = false;

  function addMsg(role: string, text: string) {
    const div = document.createElement("div");
    div.className = `msg msg-${role}`;
    div.textContent = text;
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function showOptions(opts: string[]) {
    optionsEl.innerHTML = "";
    opts.forEach((label) => {
      const btn = document.createElement("button");
      btn.className = "chat-option";
      btn.textContent = label;
      btn.type = "button";
      btn.addEventListener("click", () => handleAnswer(label));
      optionsEl.appendChild(btn);
    });
    optionsEl.hidden = false;
    input.parentElement!.hidden = true;
  }

  function showInput(placeholder = "Escribe tu respuesta...") {
    optionsEl.hidden = true;
    input.parentElement!.hidden = false;
    input.placeholder = placeholder;
    input.focus();
  }

  function runStep() {
    const step = STEPS[currentStep];
    const botText = typeof step.bot === "function" ? step.bot(data) : step.bot;

    setTimeout(() => {
      addMsg("assistant", botText);
      if (step.options) {
        showOptions(step.options);
      } else {
        showInput(step.key === "phone" ? "Ej: 612 345 678" : "Escribe tu respuesta...");
      }
    }, 400);
  }

  function handleAnswer(answer: string) {
    const step = STEPS[currentStep];

    if (step.validate) {
      const err = step.validate(answer);
      if (err) {
        addMsg("assistant", err);
        return;
      }
    }

    addMsg("user", answer);

    if (step.field) {
      const value = step.transform ? step.transform(answer) : answer;
      data[step.field] = value;
    }

    const nextKey = step.next(answer);

    if (nextKey === "send") {
      sendLead();
      return;
    }

    currentStep = STEPS.findIndex((s) => s.key === nextKey);
    runStep();
  }

  async function sendLead() {
    optionsEl.hidden = true;
    input.parentElement!.hidden = true;

    addMsg("assistant", "Enviando tus datos al equipo...");

    try {
      const res = await fetch("/api/lead-notify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: data.name,
          phone: data.phone,
          installation_type: data.installation_type,
          message: `[Chatbot] Municipio: ${data.municipality}. Tejado: ${data.own_roof}`,
        }),
      });

      if (!res.ok) throw new Error("fail");

      done = true;
      addMsg("assistant", "Datos enviados. Un técnico de Hispalense Solar te contactará en menos de 24 horas con tu presupuesto personalizado. ¡Gracias!");
    } catch {
      addMsg("assistant", "Ha habido un problema al enviar. Puedes llamarnos directamente al 954 123 456 o escribirnos por WhatsApp.");
    }
  }

  fab.addEventListener("click", () => {
    win.hidden = false;
    fab.hidden = true;
    if (currentStep === 0 && messagesEl.children.length === 0) {
      runStep();
    }
  });

  closeBtn.addEventListener("click", () => {
    win.hidden = true;
    fab.hidden = false;
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text || done) return;
    input.value = "";
    handleAnswer(text);
  });
</script>

<style>
  #chatbot {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 950;
  }

  .chat-fab {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-navy);
    color: var(--color-white);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .chat-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
  }

  .chat-fab :global(.fab-icon) {
    width: 24px;
    height: 24px;
  }

  .chat-window {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 380px;
    max-height: 520px;
    background: var(--color-white);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    background: var(--color-navy);
    color: var(--color-white);
  }

  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .chat-header-info :global(.chat-logo) {
    width: 28px;
    height: 28px;
    color: var(--color-solar-yellow);
  }

  .chat-brand {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
  }

  .chat-status {
    display: block;
    font-size: 0.75rem;
    opacity: 0.7;
  }

  .chat-close {
    background: none;
    border: none;
    color: var(--color-white);
    cursor: pointer;
    padding: 0.25rem;
    opacity: 0.7;
  }

  .chat-close:hover {
    opacity: 1;
  }

  .chat-close :global(.close-icon) {
    width: 20px;
    height: 20px;
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    min-height: 250px;
    max-height: 320px;
  }

  .chat-messages :global(.msg) {
    max-width: 85%;
    padding: 0.65rem 0.9rem;
    border-radius: 12px;
    font-size: 0.9rem;
    line-height: 1.45;
    word-break: break-word;
    white-space: pre-line;
  }

  .chat-messages :global(.msg-assistant) {
    align-self: flex-start;
    background: var(--color-offwhite);
    color: var(--color-navy);
    border-bottom-left-radius: 4px;
  }

  .chat-messages :global(.msg-user) {
    align-self: flex-end;
    background: var(--color-navy);
    color: var(--color-white);
    border-bottom-right-radius: 4px;
  }

  .chat-options {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.5rem 1rem 0.75rem;
    border-top: 1px solid #e6e9f0;
  }

  .chat-options :global(.chat-option) {
    background: var(--color-white);
    border: 1.5px solid var(--color-navy);
    color: var(--color-navy);
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }

  .chat-options :global(.chat-option:hover) {
    background: var(--color-navy);
    color: var(--color-white);
  }

  .chat-input-form {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid #e6e9f0;
  }

  .chat-input {
    flex: 1;
    border: 1px solid #e6e9f0;
    border-radius: 8px;
    padding: 0.55rem 0.75rem;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
  }

  .chat-input:focus {
    border-color: var(--color-navy);
  }

  .chat-send {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: var(--color-navy);
    color: var(--color-white);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .chat-send:hover {
    background: var(--color-solar-yellow);
    color: var(--color-navy);
  }

  .chat-send svg {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 860px) {
    #chatbot {
      bottom: 60px;
      right: 16px;
    }

    .chat-window {
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      max-height: 70vh;
      border-radius: 16px 16px 0 0;
    }

    .chat-fab {
      width: 48px;
      height: 48px;
    }

    .chat-fab :global(.fab-icon) {
      width: 20px;
      height: 20px;
    }
  }
</style>
