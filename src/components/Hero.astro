---
import Icon from "./Icon.astro";
import { site } from "../data/site";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="copy">
      <span class="eyebrow">Placas solares en Sevilla</span>
      <h1>Instalación de placas solares en Sevilla</h1>
      <p>
        Reduce tu factura eléctrica con una instalación fotovoltaica a medida.
        Estudiamos tu consumo, nos encargamos de la instalación y la legalización, y
        te acompañamos desde el primer día en Sevilla capital y en toda la provincia.
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="#presupuesto">Solicitar presupuesto gratis</a>
        <a class="btn btn-secondary" href={site.phoneHref}>
          <Icon name="phone" />
          <span>{site.phone}</span>
        </a>
      </div>
      <ul class="trust">
        <li><Icon name="check" /> Instaladores certificados en Sevilla</li>
        <li><Icon name="check" /> Presupuesto gratuito en 24h</li>
        <li><Icon name="check" /> Financiación disponible</li>
      </ul>
    </div>

    <div class="art">
      <img
        src="https://images.unsplash.com/photo-1719848576338-9516ba7ccd8b?w=1200&q=75&auto=format&fit=crop"
        alt="Técnico instalando placas solares en el tejado de una vivienda en Sevilla"
        width="1200"
        height="800"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(160deg, var(--color-navy), var(--color-navy-light));
    color: var(--color-white);
    padding: 4.5rem 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2.5rem;
    align-items: center;
  }

  .hero h1 {
    color: var(--color-white);
  }

  .hero p {
    color: rgba(255, 255, 255, 0.85);
    max-width: 48ch;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .trust {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .trust li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .trust :global(svg) {
    width: 18px;
    height: 18px;
    color: var(--color-solar-yellow);
    flex-shrink: 0;
  }

  .art img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.25);
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .art {
      order: -1;
      max-width: 320px;
      margin: 0 auto;
    }
  }
</style>
